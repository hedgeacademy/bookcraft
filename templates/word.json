{
  "output_directory": "exports",
  "filename_prefix": "",
  "filename_pattern": "{title}-{author}-{yyyyMMdd}-{HHmm}.docx",
  "paper": "16k",
  "page_width_cm": 18.4,
  "page_height_cm": 26,
  "margin_top_cm": 2.5,
  "margin_bottom_cm": 1.8,
  "margin_left_cm": 2,
  "margin_right_cm": 2,
  "header_distance_cm": 1.7,
  "footer_distance_cm": 1.3,
  "different_odd_even_pages": true,
  "different_first_page": true,
  "front_matter_show_page_number": false,
  "toc_page_number_format": "upperRoman",
  "toc_page_number_start": 1,
  "body_page_number_format": "decimal",
  "body_page_number_start": 1,
  "body_page_number_min_digits": 3,
  "grid_enabled": true,
  "characters_per_line": 40,
  "lines_per_page": 40,
  "language": "zh-CN",
  "body_font": "宋体",
  "latin_font": "Times New Roman",
  "heading_font": "黑体",
  "font_size_pt": 10.5,
  "line_spacing_multiple": 1.5,
  "first_line_indent_chars": 2,
  "include_toc": true,
  "toc_depth": 3,
  "max_heading_level": 3,
  "chapter_title_number_style": "第3章",
  "heading_transition_text_required": true,
  "code_font": "Courier New",
  "code_font_size_pt": 8,
  "code_line_spacing_multiple": 1.5,
  "figure_wrapping": "inline",
  "caption_alignment": "center",
  "caption_number_name_separator": "  ",
  "caption_blank_line_before": true,
  "caption_blank_line_after": true,
  "table_caption_position": "above",
  "metadata_config": "book.toml",
  "converter": "scripts/md2word.py"
}
